{
  "summary": "Create a BFB image for NVIDIA BlueField DPUs",
  "description": [
    "Packages Linux live artifacts into NVIDIA BFB format for BlueField DPUs.",
    "Takes kernel, initramfs, and optionally rootfs as inputs.",
    "If rootfs is provided, it is concatenated with initramfs.",
    "Boots via GRUB shims discovered from the buildroot EFI paths.",
    "Buildhost commands used: `mlx-mkbfb`"
  ],
  "schema_2": {
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kernel",
        "initramfs"
      ],
      "properties": {
        "kernel": {
          "type": "object",
          "additionalProperties": true
        },
        "initramfs": {
          "type": "object",
          "additionalProperties": true
        },
        "rootfs": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "options": {
      "additionalProperties": false,
      "required": [
        "filename"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "description": "Output BFB filename"
        },
        "kernel_args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Kernel arguments for the GRUB menu entry. Defaults include console=hvc0 (rshim virtual console), console=ttyAMA0 (IPMI serial), earlycon=pl011,0x13010000 (early serial on BF3), ignition.firstboot, and ignition.platform.id=nvidiabluefield.",
          "default": [
            "console=hvc0",
            "console=ttyAMA0",
            "earlycon=pl011,0x13010000",
            "ignition.firstboot",
            "ignition.platform.id=nvidiabluefield"
          ]
        },
        "boot_path": {
          "type": "string",
          "description": "UEFI boot path"
        },
        "boot_desc": {
          "type": "string",
          "description": "Boot entry description"
        }
      }
    }
  }
}
